function resetTimers() {
  let maxId = setTimeout(function () {}, 0);

  for (var i = 0; i < maxId; i += 1) {
    clearTimeout(i);
  }
}

const evaluateCode = (code) => {
  console.clear();
  resetUI();
  resetTimers();
  try {
    Function(code)(window);
  } catch (err) {
    console.error(err);
  }
};

